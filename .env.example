DATABASE_URL=postgres://postgres:postgres@localhost:5432/taptaptap
# Optional: when deploying app + Postgres inside Railway, prefer the private/internal URL here.
DATABASE_PRIVATE_URL=
TEACHER_DASHBOARD_PASSWORD=change-me
TEACHER_SESSION_SECRET=replace-with-long-random-secret
TZ=Asia/Seoul
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:nitro
PG_POOL_MAX=5
PG_IDLE_TIMEOUT_MS=60000
PG_CONNECTION_TIMEOUT_MS=3000
PG_ALLOW_EXIT_ON_IDLE=false
